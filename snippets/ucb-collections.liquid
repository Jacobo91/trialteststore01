{%- comment -%} Collections render snippet {%- endcomment -%}

{%- liquid
  assign collections = section.blocks | where: 'type', 'collection'
  assign limit = section.settings.collection_limit | default: 6
-%}

<div class="ucb-grid{% if layout_type == 'carousel' %} ucb-carousel{% endif %}">
  {%- for block in collections limit: limit -%}
    {%- assign collection = block.settings.collection -%}
    {%- if collection != blank -%}
      <article class="ucb-card">
        <div class="ucb-card__image">
          <a href="{{ collection.url }}">
            {%- if collection.featured_image -%}
              <img src="{{ collection.featured_image | image_url: width: 600 }}" alt="{{ collection.title }}" loading="lazy">
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag }}
            {%- endif -%}
          </a>
        </div>
        <div class="ucb-card__content">
          <h3 class="ucb-card__title">
            <a href="{{ collection.url }}">{{ collection.title }}</a>
          </h3>
          <p class="ucb-card__description">{{ collection.description | strip_html | truncate: 80 }}</p>
          <div class="ucb-card__meta">
            <span class="ucb-card__date">{{ collection.products_count }} products</span>
          </div>
          {%- if section.settings.show_shop_now -%}
            <a href="{{ collection.url }}" class="ucb-card__button">Shop Now</a>
          {%- endif -%}
        </div>
      </article>
    {%- endif -%}
  {%- endfor -%}
</div>
