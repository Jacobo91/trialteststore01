{%- comment -%} Testimonials snippet {%- endcomment -%}

{%- liquid
  assign testimonials = section.blocks | where: 'type', 'testimonial'
  assign style = section.settings.testimonial_style | default: 'cards'
-%}

<div class="ucb-testimonials ucb-{{ style }}{% if layout_type == 'carousel' %} ucb-carousel{% else %} ucb-grid{% endif %}">
  {%- for block in testimonials -%}
    <blockquote class="ucb-testimonial" {{ block.shopify_attributes }}>
      {%- if style == 'cards' -%}
        {%- if block.settings.rating > 0 -%}
          <div class="ucb-testimonial__stars">
            {%- for i in (1..block.settings.rating) -%}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {%- endfor -%}
          </div>
        {%- endif -%}
        <p class="ucb-testimonial__quote">"{{ block.settings.quote }}"</p>
        <footer class="ucb-testimonial__author">
          {%- if block.settings.avatar != blank -%}
            <img src="{{ block.settings.avatar | image_url: width: 60 }}" alt="{{ block.settings.author }}" class="ucb-testimonial__avatar">
          {%- endif -%}
          <div>
            <cite class="ucb-testimonial__name">{{ block.settings.author }}</cite>
            {%- if block.settings.role != blank -%}
              <span class="ucb-testimonial__role">{{ block.settings.role }}</span>
            {%- endif -%}
          </div>
        </footer>
      {%- else -%}
        <div class="ucb-testimonial__simple">
          <p class="ucb-testimonial__quote">"{{ block.settings.quote }}"</p>
          <cite class="ucb-testimonial__name">— {{ block.settings.author }}{% if block.settings.role %}, {{ block.settings.role }}{% endif %}</cite>
        </div>
      {%- endif -%}
    </blockquote>
  {%- endfor -%}
</div>

<style>
  .ucb-testimonials {
    --testimonial-gap: {{ grid_gap }}px;
  }
  
  .ucb-testimonial {
    margin: 0;
    padding: {{ card_padding }}px;
    background: var(--card-bg);
    border-radius: var(--card-radius);
    box-shadow: var(--card-shadow);
  }
  
  .ucb-testimonials.cards .ucb-testimonial {
    border: {% if section.settings.card_border_show %}1px solid var(--card-border){% else %}none{% endif %};
  }
  
  .ucb-testimonial__stars {
    margin-bottom: 12px;
  }
  
  .ucb-testimonial__quote {
    font-size: {{ section.settings.testimonial_font_size | default: 16 }}px;
    line-height: 1.7;
    color: var(--text-color);
    margin: 0 0 16px;
    font-style: italic;
  }
  
  .ucb-testimonial__author {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 0;
  }
  
  .ucb-testimonial__avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
  }
  
  .ucb-testimonial__name {
    font-style: normal;
    font-weight: 600;
    color: var(--heading-color);
    display: block;
  }
  
  .ucb-testimonial__role {
    font-size: 13px;
    color: var(--text-color);
  }
  
  .ucb-testimonials.simple {
    display: flex;
    flex-direction: column;
    gap: var(--testimonial-gap);
  }
  
  .ucb-testimonials.simple .ucb-testimonial {
    background: transparent;
    box-shadow: none;
    padding: 20px 0;
    border-bottom: 1px solid rgba(0,0,0,0.1);
  }
</style>
