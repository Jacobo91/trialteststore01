{%- comment -%} CTA (Call to Action) snippet {%- endcomment -%}

{%- liquid
  assign block = section.blocks | where: 'type', 'cta_block' | first
  assign bg_image = block.settings.background_image
  assign bg_overlay = section.settings.cta_overlay
  assign overlay_opacity = section.settings.cta_overlay_opacity | default: 50
-%}

<div class="ucb-cta"{% if bg_image != blank %} style="--cta-bg: url('{{ bg_image | image_url: width: 1600 }}')"{% endif %}>
  {%- if bg_image != blank or bg_overlay != blank -%}
    <div class="ucb-cta__bg"></div>
  {%- endif -%}
  
  <div class="ucb-cta__content">
    {%- if block.settings.eyebrow != blank -%}
      <span class="ucb-cta__eyebrow">{{ block.settings.eyebrow }}</span>
    {%- endif -%}
    
    {%- if block.settings.heading != blank -%}
      <h2 class="ucb-cta__heading">{{ block.settings.heading }}</h2>
    {%- endif -%}
    
    {%- if block.settings.subtext != blank -%}
      <p class="ucb-cta__subtext">{{ block.settings.subtext }}</p>
    {%- endif -%}
    
    <div class="ucb-cta__buttons">
      {%- if block.settings.button_text != blank and block.settings.button_link != blank -%}
        <a href="{{ block.settings.button_link }}" class="ucb-card__button">{{ block.settings.button_text }}</a>
      {%- endif -%}
      
      {%- if block.settings.secondary_button_text != blank and block.settings.secondary_button_link != blank -%}
        <a href="{{ block.settings.secondary_button_link }}" class="ucb-card__button ucb-card__button--secondary">{{ block.settings.secondary_button_text }}</a>
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  .ucb-cta {
    position: relative;
    text-align: {{ section.settings.cta_alignment | default: 'center' }};
    padding: {{ section.settings.cta_padding | default: 80 }}px 20px;
    overflow: hidden;
  }
  
  .ucb-cta__bg {
    position: absolute;
    inset: 0;
    background-image: var(--cta-bg);
    background-size: cover;
    background-position: center;
    z-index: 0;
  }
  
  {%- if bg_overlay != blank -%}
    .ucb-cta__bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: {{ bg_overlay }};
      opacity: {{ overlay_opacity | divided_by: 100 }};
    }
  {%- endif -%}
  
  .ucb-cta__content {
    position: relative;
    z-index: 1;
    max-width: 700px;
    margin: 0 auto;
  }
  
  .ucb-cta__eyebrow {
    display: inline-block;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--link-color);
    margin-bottom: 16px;
  }
  
  .ucb-cta__heading {
    font-size: {{ section.settings.cta_heading_size | default: 42 }}px;
    font-weight: 700;
    color: var(--heading-color);
    margin: 0 0 16px;
    line-height: 1.2;
  }
  
  .ucb-cta__subtext {
    font-size: {{ section.settings.cta_text_size | default: 18 }}px;
    color: var(--text-color);
    margin: 0 0 32px;
    line-height: 1.6;
  }
  
  .ucb-cta__buttons {
    display: flex;
    gap: 16px;
    justify-content: {{ section.settings.cta_button_alignment | default: 'center' }};
    flex-wrap: wrap;
  }
  
  .ucb-card__button--secondary {
    background: transparent;
    border: 2px solid var(--btn-bg);
    color: var(--btn-bg);
  }
  
  .ucb-card__button--secondary:hover {
    background: var(--btn-bg);
    color: var(--btn-color);
  }
</style>
